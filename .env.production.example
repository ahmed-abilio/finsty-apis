# Copy to .env on the production server:
#   cp .env.production.example .env

# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
API_PREFIX=/api/v1

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-long-random-secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ─── PostgreSQL (external — Neon, RDS, etc.) ─────────────────────────────────
DB_HOST=your-db-host.example.com
DB_PORT=5432
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000
DB_LOGGING=false

# Run migrations when the app container starts
RUN_MIGRATIONS_ON_START=true

# ─── Redis (docker-compose.prod.yml — app uses hostname "redis") ─────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me-strong-redis-password
REDIS_DB=0
REDIS_KEY_PREFIX=finsty:

# ─── Firebase (file mounted by docker-compose.prod.yml) ────────────────────
FIREBASE_SERVICE_ACCOUNT_PATH=/run/secrets/firebase-service-account.json
FIREBASE_PROJECT_ID=your-firebase-project-id

NOTIFICATION_RATE_ORDER_DELAY_MS=86400000

# ─── AWS S3 ──────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET_NAME=
S3_PRESIGNED_URL_EXPIRES=3600

# ─── Admin / payments ────────────────────────────────────────────────────────
ADMIN_API_KEY=change-me-admin-api-key
PAYMENT_PROVIDER=razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ─── CORS (your live admin + app URLs) ───────────────────────────────────────
CORS_ORIGINS=https://admin.yourdomain.com,https://app.yourdomain.com

RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

TAX_RATE=0.18
PLATFORM_FEE=0

# ─── Shadowfax ───────────────────────────────────────────────────────────────
SHADOWFAX_SERVICEABILITY_URL=
SHADOWFAX_PLACE_ORDER_URL=
SHADOWFAX_ORDER_STATUS_URL=
SHADOWFAX_CANCEL_ORDER_URL=
SHADOWFAX_DISPATCH_READY_URL=
SHADOWFAX_API_KEY=
SHADOWFAX_CLIENT_CODE=
SHADOWFAX_REQUEST_TIMEOUT_MS=30000
SHADOWFAX_PICKUP_CONTACT=
SHADOWFAX_WEBHOOK_SECRET=
SHADOWFAX_WEBHOOK_HEADER_NAME=x-shadowfax-secret
SHADOWFAX_WEBHOOK_RATE_LIMIT_MAX=300
SHADOWFAX_WEBHOOK_RATE_LIMIT_WINDOW_MS=60000
