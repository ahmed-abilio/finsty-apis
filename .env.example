# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
API_PREFIX=/api/v1

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=finsty_db
DB_USER=finsty_user
DB_PASSWORD=finsty_password
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000
DB_LOGGING=false

# Run Sequelize migrations when the Docker container starts (default: true)
RUN_MIGRATIONS_ON_START=true

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=finsty:

# ─── Firebase Admin SDK ────────────────────────────────────────────────────────
# Option A: Path to service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Option B: Inline JSON (for Docker / CI environments)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

FIREBASE_PROJECT_ID=your-firebase-project-id

# Push notifications (FCM) — delay before "rate your order" reminder (default 24h)
NOTIFICATION_RATE_ORDER_DELAY_MS=86400000

# ─── AWS S3 ────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-s3-bucket-name
S3_PRESIGNED_URL_EXPIRES=3600

# ─── Bull Board Admin ──────────────────────────────────────────────────────────
ADMIN_API_KEY=change-this-admin-api-key

# Bootstrap secret for POST /api/v1/auth/admin/create
SUPER_KEY=change-this-super-key

# ─── Razorpay ──────────────────────────────────────────────────────────────────
PAYMENT_PROVIDER=razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ─── Pricing (cart + checkout) ───────────────────────────────────────────────
# GST rate applied to merchandise subtotal (selected cart lines), e.g. 0.18 = 18%
TAX_RATE=0.18
# Fixed platform fee per order in INR (not a percentage)
PLATFORM_FEE=0

# ─── Shadowfax (all endpoint URLs required; no hardcoded defaults in code) ─────
SHADOWFAX_SERVICEABILITY_URL=https://private-anon-3e6934dd12-sfxhlmarketplaceapi.apiary-proxy.com/api/v1/order-serviceability/
SHADOWFAX_PLACE_ORDER_URL=https://private-anon-3e6934dd12-sfxhlmarketplaceapi.apiary-proxy.com/api/v2/orders/
SHADOWFAX_ORDER_STATUS_URL=https://private-anon-3e6934dd12-sfxhlmarketplaceapi.apiary-proxy.com/api/v2/orders/{id}/status/
SHADOWFAX_API_KEY=your-shadowfax-api-token
SHADOWFAX_CLIENT_CODE=your_client_code
# HTTP timeout for Shadowfax API calls (ms). Default: 30000
SHADOWFAX_REQUEST_TIMEOUT_MS=30000
# Fallback pickup phone when store.phone is empty
SHADOWFAX_PICKUP_CONTACT=

# ─── Shadowfax webhooks ───────────────────────────────────────────────────────
SHADOWFAX_WEBHOOK_SECRET=
SHADOWFAX_WEBHOOK_HEADER_NAME=x-shadowfax-secret
SHADOWFAX_WEBHOOK_RATE_LIMIT_MAX=300
SHADOWFAX_WEBHOOK_RATE_LIMIT_WINDOW_MS=60000
# Development only (platform_settings table):
#   shadowfax_dev_local_callback_enabled — poll Shadowfax and sync local DB (no ngrok)
#   shadowfax_dev_local_callback_base_url — e.g. http://localhost:3001
# Enable via SQL:
#   UPDATE platform_settings SET value = 'true' WHERE key = 'shadowfax_dev_local_callback_enabled';
# Or PATCH /api/v1/admin/platform-settings/shadowfax-dev-local-callback { "enabled": true }
